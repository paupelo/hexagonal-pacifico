# Cadena de conexión a PostgreSQL.
# En LOCAL apunta a tu base de datos local, por ejemplo:
#   postgres://usuario:contrasena@localhost:5432/hexagonal
# En RENDER esta variable se inyecta automáticamente al enlazar la base de datos
# (usa la "Internal Database URL" que te da Render).
DATABASE_URL=postgres://usuario:contrasena@localhost:5432/hexagonal

# Contraseña del panel de administración del torneo.
# NUNCA se escribe en el código: el servidor la lee de aquí.
# Cámbiala por una contraseña fuerte y secreta.
ADMIN_PASSWORD=cambia-esta-contrasena

# Puerto local (opcional). Render lo inyecta automáticamente en producción.
PORT=3000
